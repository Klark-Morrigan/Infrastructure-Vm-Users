{#
  Per-user /etc/sudoers.d/<username> drop-in. Rules are written
  verbatim from config - no parsing, no quoting, no field validation.
  visudo -cf (configured on the calling task) is the gate that catches
  malformed entries before the atomic swap, so a typo fails the play
  rather than landing in /etc/sudoers.d/.
-#}
# Managed by Common-Ansible roles/sudoers - do not edit by hand.
# Source: VmUsersConfig vault entry for {{ inventory_hostname }}, user
# {{ item.username }}.
{% for rule in item.sudoersRules -%}
{{ rule }}
{% endfor -%}
